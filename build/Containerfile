FROM --platform=linux/amd64 docker.io/library/debian:trixie-slim

# Principle of least privilege: create a new user for running the application
RUN groupadd -g 10001 windrose && \
    useradd -r -u 10001 -g windrose -s /bin/bash --create-home windrose

RUN apt-get update \
    && apt-get install --no-install-recommends -y \
    python3 \
    ca-certificates \
    libcurl4 \
    netcat-traditional \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*


WORKDIR /srv/windrose

RUN chown -R windrose:windrose /srv/windrose

COPY --from=docker.io/windroseserver/windroseserver:latest --chown=windrose:windrose /home/ue_user/app /srv/windrose

COPY --chown=windrose:windrose scripts/start_linux.sh /srv/windrose/start_linux.sh

COPY --chown=windrose:windrose scripts/update_server_description.py /srv/windrose/update_server_description.py

COPY --chown=windrose:windrose scripts/ServerDescription.json /srv/windrose/R5/ServerDescription.json

RUN chmod +x /srv/windrose/start_linux.sh

EXPOSE 28050/tcp 28050/udp

# Use the unpriviledged user to run the application
USER 10001

ENTRYPOINT ["/srv/windrose/start_linux.sh"]
